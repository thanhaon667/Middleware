{
    "kind": "collectionType",
    "collectionName": "platform_connections",
    "info": {
        "singularName": "platform-connection",
        "pluralName": "platform-connections",
        "displayName": "PlatformConnection"
    },
    "options": {
        "draftAndPublish": true
    },
    "pluginOptions": {},
    "attributes": {
        "client": {
            "type": "relation",
            "relation": "manyToOne",
            "target": "api::client.client",
            "inversedBy": "platform_connections"
        },
        "platformType": {
            "type": "enumeration",
            "enum": [
                "MISA",
                "KIOSK",
                "SAPO",
                "SM"
            ]
        },
        "direction": {
            "type": "enumeration",
            "enum": [
                "source",
                "target"
            ]
        },
        "apiUrl": {
            "type": "string"
        },
        "webhookSecret": {
            "type": "string"
        },
        "config": {
            "type": "json"
        },
        "accessToken": {
            "type": "string"
        },
        "tokenExpiresAt": {
            "type": "datetime"
        },
        "isActive": {
            "type": "boolean",
            "default": true
        },
        "orders": {
            "type": "relation",
            "relation": "oneToMany",
            "target": "api::order.order",
            "mappedBy": "platform_connection"
        }
    }
}
